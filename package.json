{
  "name": "structure-viewer-electron",
  "version": "1.0.0",
  "description": "Desktop app wrapper for Minecraft Structure Viewer",
  "main": "main.js",

  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },

"build": {
  "appId": "com.createmodfan.structureviewer",
  "productName": "Structure Viewer Wrapper",

  "win": {
    "icon": "icon.ico",
    "target": [
      "nsis",
      "portable"
    ]
  },

  "linux": {
    "icon": "icon.png",
    "target": [
      "AppImage",
      "deb"
    ],
    "category": "Utility"
  },

  "mac": {
    "icon": "icon.icns",
    "target": [
      "dmg"
    ]
  }
},

  "author": {
  "name": "CreateModFan154",
  "email": "electron-contact@cmf12.simplelogin.com"
},
  
  "devDependencies": {
    "electron": "^43.1.0",
    "electron-builder": "^26.0.0"
  }
}
