{
  "name": "structure-viewer-electron",
  "version": "1.0.0",
  "description": "Desktop app wrapper for Minecraft Structure Viewer",
  "main": "main.js",

  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },

"build": {
  "appId": "com.createmodfan.structureviewer",
  "productName": "Structure Viewer Wrapper",

  "win": {
    "target": [
      "nsis",
      "portable"
    ]
  },

  "linux": {
    "target": [
      "AppImage",
      "deb"
    ]
  },

  "mac": {
    "target": [
      "dmg"
    ]
  }
}

  "devDependencies": {
    "electron": "^43.1.0",
    "electron-builder": "^26.0.0"
  }
}
